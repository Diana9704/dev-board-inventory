{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "api/auth.js", "use": "@vercel/node" },
    { "src": "api/boards.js", "use": "@vercel/node" },
    { "src": "api/users.js", "use": "@vercel/node" },
    { "src": "api/logs.js", "use": "@vercel/node" },
    { "src": "api/import.js", "use": "@vercel/node" },
    { "src": "api/health.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/auth/(.*)", "dest": "/api/auth.js" },
    { "src": "/api/boards/(.*)", "dest": "/api/boards.js" },
    { "src": "/api/users/(.*)", "dest": "/api/users.js" },
    { "src": "/api/logs/(.*)", "dest": "/api/logs.js" },
    { "src": "/api/import/(.*)", "dest": "/api/import.js" },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/(.*)", "dest": "/dist/$1" },
    { "src": "/(.*)", "dest": "/dist/index.html" }
  ]
}